# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# LinkedIn (session cookie - grab from browser dev tools)
LINKEDIN_SESSION_COOKIE=your_li_at_cookie_here

# Indeed
INDEED_API_KEY=optional

# Anthropic Claude (for cover letter generation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Job Preferences
TARGET_ROLE=Senior Product Manager
MIN_SALARY=80000
LOCATIONS=EMEA,Remote,US
MAX_JOBS_PER_DAY=50

# Resume
RESUME_PATH=config/resume.pdf

# Applicant PII (used for form filling)
APPLICANT_NAME=Your Full Name
APPLICANT_FIRST_NAME=Your
APPLICANT_LAST_NAME=Name
APPLICANT_EMAIL=you@example.com
APPLICANT_PHONE=+1 555 000 0000
APPLICANT_LINKEDIN=https://www.linkedin.com/in/yourprofile
APPLICANT_WEBSITE=https://yoursite.com
APPLICANT_PORTFOLIO=https://portfolio.yoursite.com

# Pre-built form answers
ANSWER_SALARY=$80,000 - $120,000 depending on total compensation package
ANSWER_AVAILABILITY=Available to start within 2-4 weeks
ANSWER_WORK_AUTH=Based in Turkey, authorized to work in EMEA. Open to relocation and can work US timezone hours.
ANSWER_REMOTE=Yes, I have extensive experience working remotely with distributed teams across Turkey, UAE, KSA, and the US.
ANSWER_YOE=8+
